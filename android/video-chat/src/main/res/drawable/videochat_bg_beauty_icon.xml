<?xml version="1.0" encoding="utf-8"?>
<!-- 美颜按钮图标背景：半透明黑底圆形，白色边框 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#66000000" />
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>
</selector>
