<?xml version="1.0" encoding="utf-8"?>
<!-- 在线状态绿色圆点 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 白色边框 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- 绿色圆心 -->
    <item
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:top="1.5dp">
        <shape android:shape="oval">
            <solid android:color="#22C55E" />
        </shape>
    </item>
</layer-list>
