<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout"
    tools:orientation="horizontal"
    tools:background="@drawable/videochat_bg_profile_bottom_bar"
    tools:padding="16dp">

    <LinearLayout
        android:id="@+id/btn_chat"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_weight="1"
        android:layout_marginEnd="10dp"
        android:background="@drawable/videochat_bg_btn_chat"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_chat_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:importantForAccessibility="no"
            android:src="@drawable/videochat_ic_chat_bubble_dots" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.08"
            android:text="@string/videochat_btn_chat"
            android:textColor="@color/videochat_color_white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_call"
        android:layout_width="56dp"
        android:layout_height="50dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/videochat_bg_icon_btn"
        android:importantForAccessibility="no"
        android:padding="13dp"
        android:scaleType="centerInside"
        android:src="@drawable/videochat_ic_call_icon"
        app:tint="#FFB44FFF" />

    <LinearLayout
        android:id="@+id/btn_follow"
        android:layout_width="56dp"
        android:layout_height="50dp"
        android:background="@drawable/videochat_bg_icon_btn"
        android:gravity="center"
        android:orientation="horizontal">

        <io.trtc.uikit.videochat.common.widget.button.FollowButton
            android:id="@+id/iv_follow_icon"
            android:layout_width="32dp"
            android:layout_height="32dp" />
    </LinearLayout>

</merge>
