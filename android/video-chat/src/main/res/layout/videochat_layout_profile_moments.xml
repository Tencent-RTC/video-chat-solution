<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout"
    tools:orientation="vertical"
    tools:padding="14dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/videochat_moments"
        android:textColor="@color/videochat_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_photo_0"
                style="@style/VideoChatPhotoCell"
                android:layout_marginEnd="4dp"
                tools:background="@color/videochat_avatar_placeholder" />

            <ImageView
                android:id="@+id/iv_photo_1"
                style="@style/VideoChatPhotoCell"
                android:layout_marginEnd="4dp"
                tools:background="@color/videochat_avatar_placeholder" />

            <ImageView
                android:id="@+id/iv_photo_2"
                style="@style/VideoChatPhotoCell"
                tools:background="@color/videochat_avatar_placeholder" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_photo_3"
                style="@style/VideoChatPhotoCell"
                android:layout_marginEnd="4dp"
                tools:background="@color/videochat_avatar_placeholder" />

            <ImageView
                android:id="@+id/iv_photo_4"
                style="@style/VideoChatPhotoCell"
                android:layout_marginEnd="4dp"
                tools:background="@color/videochat_avatar_placeholder" />

            <ImageView
                android:id="@+id/iv_photo_5"
                style="@style/VideoChatPhotoCell"
                tools:background="@color/videochat_avatar_placeholder" />
        </LinearLayout>
    </LinearLayout>

</merge>
